{
  "name": "diveni-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "serve": "vite --port 8080",
    "build": "vite build",
    "preview": "vite preview",
    "lint:ci": "eslint \"src/**/*.{ts,vue}\" --max-warnings=0 --no-fix && npm run prettier -- --check",
    "lint": "eslint \"src/**/*.{ts,vue}\" --no-fix && npm run prettier -- --check",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix && npm run prettier -- --write",
    "prettier": "prettier \"src/**/*.{vue,css,html,ts,js}\"",
    "licenses:update": "license-checker --json > ./public/frontend-dependencies.json"
  },
  "dependencies": {
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/editor-plugin-code-syntax-highlight": "^3.1.0",
    "axios": "^1.13.6",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.44.0",
    "canvas-confetti": "^1.9.4",
    "gsap": "^3.14.2",
    "hammerjs": "^2.0.8",
    "jira2md": "^3.0.1",
    "papaparse": "^5.5.3",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.8.0",
    "sockjs-client": "^1.6.1",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-debounce": "^5.0.1",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "vue-toastification": "^2.0.0-rc.5",
    "vue3-steppy": "^1.6.0",
    "webstomp-client": "^1.2.6"
  },
  "devDependencies": {
    "@crowdin/cli": "^4.14.1",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/canvas-confetti": "^1.9.0",
    "@types/hammerjs": "^2.0.46",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass": "~1.98.0",
    "typescript": "~5.9.3",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "overrides": {
    "dompurify": "^3.3.3",
    "serialize-javascript": "^7.0.4"
  },
  "lint-staged": {
    "*.ts": "npm run lint:fix",
    "*.vue": "npm run lint:fix"
  }
}
