{
  "name": "diveni-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "serve": "vite --port 8080",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.vue --no-fix && npm run prettier -- --check",
    "lint:fix": "eslint src --ext .ts,.vue --fix && npm run prettier -- --write",
    "prettier": "prettier \"src/**/*.{vue,css,html,ts,js}\"",
    "licenses:update": "license-checker --json > ./public/frontend-dependencies.json"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/editor-plugin-code-syntax-highlight": "^3.1.0",
    "axios": "^1.10.0",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "bootstrap-vue-next": "^0.44.0",
    "canvas-confetti": "^1.9.3",
    "gsap": "^3.12.7",
    "hammerjs": "^2.0.8",
    "jira2md": "^3.0.1",
    "papaparse": "^5.5.2",
    "pinia": "^2.3.1",
    "qrcode.vue": "^3.6.0",
    "sockjs-client": "^1.6.1",
    "uuid": "^9.0.1",
    "vue": "^3.5.28",
    "vue-debounce": "^5.0.0",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.5.1",
    "vue-toastification": "^2.0.0-rc.5",
    "vue3-steppy": "^1.5.6",
    "webstomp-client": "^1.2.6"
  },
  "devDependencies": {
    "@crowdin/cli": "^4.13.0",
    "@types/canvas-confetti": "^1.6.4",
    "@types/hammerjs": "^2.0.45",
    "@types/papaparse": "^5.3.16",
    "@types/sockjs-client": "^1.5.4",
    "@types/uuid": "^8.3.1",
    "@typescript-eslint/eslint-plugin": "^4.18.0",
    "@typescript-eslint/parser": "^4.18.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/compiler-sfc": "^3.5.28",
    "@vue/eslint-config-prettier": "^6.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "eslint": "^7.32.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-vue": "^9.33.0",
    "license-checker": "^25.0.1",
    "lint-staged": "^13.3.0",
    "prettier": "^2.8.8",
    "sass": "~1.97.3",
    "typescript": "~5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  },
  "lint-staged": {
    "*.ts": "npm run lint:fix",
    "*.vue": "npm run lint:fix"
  }
}
